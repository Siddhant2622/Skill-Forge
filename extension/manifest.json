{
  "manifest_version": 3,
  "name": "SkillMap AI (New)",
  "version": "1.2",
  "description": "Auto-fill forms and get instant AI recommendations based on your SkillMap AI profile.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
